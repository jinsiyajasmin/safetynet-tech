# Copy to `.env` in the project root for Docker Compose (same file `docker-compose.yml`
# references via `env_file`). Never commit `.env` with real passwords.

# --- Neon (or any external Postgres) ---
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Local default (omit DATABASE_URL when using bundled Postgres in docker-compose.yml) ---
# DATABASE_URL=postgresql://safetyuser:safetypassword@db:5432/safetyapp_db?schema=public

# Add your other backend secrets here (JWT, Cloudinary, etc.) as needed by server.js.
